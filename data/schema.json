{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Acomodação Concorrente / Referência - Sonar Caju",
  "type": "object",
  "properties": {
    "id": { "type": "string", "description": "Identificador único (ex: airbnb_123456 ou booking_987654)" },
    "name": { "type": "string", "description": "Nome da acomodação ou anúncio" },
    "platform": { "type": "string", "enum": ["Airbnb", "Booking", "Direto", "Outro"] },
    "url": { "type": "string", "format": "uri" },
    "type": { "type": "string", "enum": ["Apartamento", "Casa", "Hotel", "Pousada", "Studio"] },
    "isFavorite": { "type": "boolean", "default": false, "description": "Se faz parte da lista restrita de favoritos mapeados pelo pai" },
    "isBenchmark": { "type": "boolean", "default": false, "description": "Se é um benchmark principal de precificação (ex: Arcus Hotel)" },
    "location": {
      "type": "object",
      "properties": {
        "address": { "type": "string" },
        "neighborhood": { "type": "string", "default": "Atalaia" },
        "lat": { "type": "number" },
        "lng": { "type": "number" },
        "distanceToBeachKm": { "type": "number" }
      },
      "required": ["lat", "lng"]
    },
    "features": {
      "type": "object",
      "properties": {
        "bedrooms": { "type": "integer" },
        "bathrooms": { "type": "integer" },
        "maxGuests": { "type": "integer" },
        "hasPool": { "type": "boolean" },
        "hasAirCond": { "type": "boolean" },
        "hasParking": { "type": "boolean" },
        "hasSeaView": { "type": "boolean" },
        "rating": { "type": "number" },
        "reviewCount": { "type": "integer" }
      }
    },
    "pricing": {
      "type": "object",
      "properties": {
        "basePrice": { "type": "number" },
        "cleaningFee": { "type": "number", "default": 0 },
        "calendar": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "startDate": { "type": "string", "format": "date" },
              "endDate": { "type": "string", "format": "date" },
              "pricePerNight": { "type": "number" },
              "minNights": { "type": "integer" },
              "isAvailable": { "type": "boolean" },
              "seasonNote": { "type": "string" }
            }
          }
        }
      }
    },
    "images": {
      "type": "array",
      "items": { "type": "string", "format": "uri" }
    },
    "lastUpdated": { "type": "string", "format": "date-time" }
  },
  "required": ["id", "name", "platform", "location", "pricing"]
}
